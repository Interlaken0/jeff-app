# Lemon Squeezy configuration
# Used for advanced account-level API calls (e.g., fetching order history).
# The public license activation endpoint does not require this key.
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_api_key_here

# Lemon Squeezy hosted checkout / payment overlay URL for the landing page CTA.
NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/buy/xxxxxx

# The public base URL of this application.
# Used to construct temporary secure download links (e.g., http://localhost:3000).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# A strong random secret used to sign temporary download tokens server-side.
# Minimum 32 characters recommended. Treat this like a password.
DOWNLOAD_SECRET=change-me-to-a-long-random-string-min-32-chars

# The final secure storage location of the digital product.
# This can be an S3 pre-signed URL, a Cloudflare R2 link, or any direct file URL.
# Users never see this URL directly; they are redirected through the secure token gate.
SECURE_DOWNLOAD_URL=https://your-cdn.com/path-to-your-product.zip
